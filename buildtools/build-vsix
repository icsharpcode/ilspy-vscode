#!/usr/bin/env sh

SEMVER=`buildtools/versionize`
PRERELEASETAG=`buildtools/versionize --type`

mkdir ./artifacts

cd ./vscode-extension
npm version --git-tag-version false --allow-same-version true -- $SEMVER
if [ -n "$PRERELEASETAG" ]; then
   npm pkg set preview='true'
fi
pnpm install
pnpm build:vsix -o ../artifacts/ilspy-vscode-$SEMVER.vsix

echo "// ILSpy VSCode Extension, v$SEMVER" > ../artifacts/extension-types.ts
cat src/extension-types.ts >> ../artifacts/extension-types.ts

echo "// ILSpy VSCode Extension, v$SEMVER" > ../artifacts/extension-api.ts
cat src/extension-api.ts >> ../artifacts/extension-api.ts
